diff --git a/implement.h b/implement.h
index 78623e9..3fd247c 100644
--- a/implement.h
+++ b/implement.h
@@ -274,6 +274,32 @@ struct pthread_mutex_t_
                     robustNode; /* Extra state for robust mutexes  */
 };
 
+static HANDLE
+__ptw32_mutex_get_event (pthread_mutex_t mx)
+{
+  HANDLE event = (HANDLE) InterlockedCompareExchangePointer (
+      (PVOID volatile *) &mx->event, NULL, NULL);
+  if (event == NULL)
+    {
+      HANDLE candidate = CreateEvent (NULL, __PTW32_FALSE, __PTW32_FALSE, NULL);
+      if (candidate == NULL)
+        {
+          return NULL;
+        }
+      event = (HANDLE) InterlockedCompareExchangePointer (
+          (PVOID volatile *) &mx->event, candidate, NULL);
+      if (event != NULL)
+        {
+          CloseHandle (candidate);
+        }
+      else
+        {
+          event = candidate;
+        }
+    }
+  return event;
+}
+
 enum __ptw32_robust_state_t_
 {
    __PTW32_ROBUST_CONSISTENT,
