{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://creator-studio.local/schemas/transcript.schema.json",
  "title": "Creator Studio Transcript",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "language", "sourceId", "segments"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "language": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,8}(-[A-Za-z0-9]{1,8})*$"
    },
    "sourceId": { "type": "string", "minLength": 1 },
    "segments": {
      "type": "array",
      "items": { "$ref": "#/definitions/segment" }
    }
  },
  "definitions": {
    "timeRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startNs", "durationNs"],
      "properties": {
        "startNs": { "type": "integer", "minimum": 0 },
        "durationNs": { "type": "integer", "minimum": 1 }
      }
    },
    "word": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "timeRange", "confidence"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "timeRange": { "$ref": "#/definitions/timeRange" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "timeRange", "words"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "timeRange": { "$ref": "#/definitions/timeRange" },
        "speaker": { "type": "string", "minLength": 1 },
        "words": {
          "type": "array",
          "items": { "$ref": "#/definitions/word" }
        }
      }
    }
  }
}
