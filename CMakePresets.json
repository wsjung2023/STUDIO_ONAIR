{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CS_BUILD_TESTS": "ON",
        "CS_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows Debug (MSVC + Ninja)",
      "description": "Run from a Developer PowerShell, or source vcvars64.bat first.",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "windows-release",
      "displayName": "Windows Release (MSVC + Ninja)",
      "description": "Run from a Developer PowerShell, or source vcvars64.bat first.",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "windows-ffmpeg-debug",
      "displayName": "Windows Debug with audited FFmpeg",
      "inherits": "windows-debug",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CS_ENABLE_FFMPEG": "ON",
        "CS_FFMPEG_ROOT": "${sourceDir}/build/ffmpeg/vcpkg_installed/x64-windows"
      }
    },
    {
      "name": "windows-ffmpeg-release",
      "displayName": "Windows Release with audited FFmpeg",
      "inherits": "windows-release",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CS_ENABLE_FFMPEG": "ON",
        "CS_FFMPEG_ROOT": "${sourceDir}/build/ffmpeg/vcpkg_installed/x64-windows"
      }
    },
    {
      "name": "windows-rnnoise-debug",
      "displayName": "Windows Debug with audited RNNoise",
      "inherits": "windows-debug",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CS_ENABLE_RNNOISE": "ON",
        "CS_RNNOISE_ROOT": "${sourceDir}/build/rnnoise/prefix"
      }
    },
    {
      "name": "windows-rnnoise-release",
      "displayName": "Windows Release with audited RNNoise",
      "inherits": "windows-release",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CS_ENABLE_RNNOISE": "ON",
        "CS_RNNOISE_ROOT": "${sourceDir}/build/rnnoise/prefix"
      }
    },
    {
      "name": "windows-whisper-debug",
      "displayName": "Windows Debug with audited whisper.cpp",
      "inherits": "windows-debug",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CS_ENABLE_WHISPER": "ON",
        "CS_WHISPER_ROOT": "${sourceDir}/build/whisper/prefix"
      }
    },
    {
      "name": "windows-whisper-release",
      "displayName": "Windows Release with audited whisper.cpp",
      "inherits": "windows-release",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CS_ENABLE_WHISPER": "ON",
        "CS_WHISPER_ROOT": "${sourceDir}/build/whisper/prefix"
      }
    },
    {
      "name": "macos-debug",
      "displayName": "macOS Debug (AppleClang + Ninja)",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "13.0"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release (AppleClang + Ninja)",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "13.0"
      }
    }
  ],
  "buildPresets": [
    { "name": "windows-debug", "configurePreset": "windows-debug" },
    { "name": "windows-release", "configurePreset": "windows-release" },
    { "name": "windows-ffmpeg-debug", "configurePreset": "windows-ffmpeg-debug" },
    { "name": "windows-ffmpeg-release", "configurePreset": "windows-ffmpeg-release" },
    { "name": "windows-rnnoise-debug", "configurePreset": "windows-rnnoise-debug" },
    { "name": "windows-rnnoise-release", "configurePreset": "windows-rnnoise-release" },
    { "name": "windows-whisper-debug", "configurePreset": "windows-whisper-debug" },
    { "name": "windows-whisper-release", "configurePreset": "windows-whisper-release" },
    { "name": "macos-debug", "configurePreset": "macos-debug" },
    { "name": "macos-release", "configurePreset": "macos-release" }
  ],
  "testPresets": [
    {
      "name": "test-base",
      "hidden": true,
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": false }
    },
    { "name": "windows-debug", "inherits": "test-base", "configurePreset": "windows-debug" },
    { "name": "windows-release", "inherits": "test-base", "configurePreset": "windows-release" },
    { "name": "windows-ffmpeg-debug", "inherits": "test-base", "configurePreset": "windows-ffmpeg-debug" },
    { "name": "windows-ffmpeg-release", "inherits": "test-base", "configurePreset": "windows-ffmpeg-release" },
    { "name": "windows-rnnoise-debug", "inherits": "test-base", "configurePreset": "windows-rnnoise-debug" },
    { "name": "windows-rnnoise-release", "inherits": "test-base", "configurePreset": "windows-rnnoise-release" },
    { "name": "windows-whisper-debug", "inherits": "test-base", "configurePreset": "windows-whisper-debug" },
    { "name": "windows-whisper-release", "inherits": "test-base", "configurePreset": "windows-whisper-release" },
    { "name": "macos-debug", "inherits": "test-base", "configurePreset": "macos-debug" },
    { "name": "macos-release", "inherits": "test-base", "configurePreset": "macos-release" }
  ]
}
